# PostgreSQL — Railway connection string
DATABASE_URL=postgresql://user:pass@host:port/db

# ScrapeCreators — https://scrapecreators.com (for post + company scraping)
SCRAPECREATORS_API_KEY=sc_xxx
SCRAPECREATORS_RATE_DELAY_MS=200

# Claude — OAuth bearer from `claude setup-token` (subscription-scoped, Haiku only).
# For Sonnet/Opus see DEPLOY.md section 6 (swap to ANTHROPIC_API_KEY).
ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...

# API server
PORT=3030
NODE_ENV=development

# Production CORS — set to the Vercel dashboard URL when the backend is
# deployed separately. Leave unset / '*' for local dev.
# CORS_ORIGIN=https://your-dashboard.vercel.app
